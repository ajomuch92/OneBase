{
  "compilerOptions": {
    "target":                     "ESNext",
    "module":                     "ESNext",
    "moduleResolution":           "bundler",
    "allowImportingTsExtensions": true,
    "strict":                     true,
    "noEmit":                     true,
    "jsx":                        "react-jsx",
    "jsxImportSource":            "hono/jsx",
    "types": ["bun"],
    "paths": {
      "onebase":   ["./src/index.ts"],
      "onebase/*": ["./src/*"]
    }
  },
  "include": ["src", "schema", "jobs"]
}
