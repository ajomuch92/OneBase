{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "noEmit": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "OneBase": ["./src/index.ts"],
      "OneBase/*": ["./src/*"]
    }
  },
  "include": ["src", "schema"]
}
