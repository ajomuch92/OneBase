# ─── Database ─────────────────────────────────────────────────────────────
# ONEBASE_DB_CLIENT selects the storage engine: sqlite | mysql | postgres
# Bun loads this file automatically — no extra setup needed.

ONEBASE_DB_CLIENT=sqlite

# --- sqlite ---
# Path to the local database file. Also settable via `--db` on the CLI.
ONEBASE_DB_PATH=./onebase.db

# --- mysql / postgres ---
# Either set ONEBASE_DB_URL (takes priority)...
# ONEBASE_DB_URL=mysql://user:password@localhost:3306/onebase
# ONEBASE_DB_URL=postgres://user:password@localhost:5432/onebase
#
# ...or the discrete fields below:
# ONEBASE_DB_HOST=localhost
# ONEBASE_DB_PORT=3306
# ONEBASE_DB_USER=root
# ONEBASE_DB_PASSWORD=
# ONEBASE_DB_NAME=onebase
# ONEBASE_DB_SSL=false

# ─── Auth ─────────────────────────────────────────────────────────────────
ONEBASE_JWT_SECRET=change-me-in-production
ONEBASE_ADMIN_EMAIL=
ONEBASE_ADMIN_PASSWORD=

# ─── Server ───────────────────────────────────────────────────────────────
ONEBASE_CORS_ORIGIN=*
ONEBASE_UPLOAD_DIR=./uploads
ONEBASE_MAX_FILE_SIZE=10485760

# Set to "true" to allow drop_column / modify_column migrations to run
# automatically instead of being skipped with a warning.
ONEBASE_ALLOW_DESTRUCTIVE=
